      <column caption='Home_Points' datatype='integer' name='[Calculation_2248985064449302535]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [FullTimeResult] == &apos;H&apos; Then 3&#13;&#10;ELSEIF [FullTimeResult] == &apos;D&apos; THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='Away_points' datatype='integer' name='[Calculation_2248985064449966088]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [FullTimeResult] =&apos;A&apos; then 3&#13;&#10;ELSEIF  [FullTimeResult] = &apos;D&apos; then 1&#13;&#10;else 0&#13;&#10;end' />
      </column>
      <column caption='Total_points' datatype='integer' name='[Calculation_2248985064450301961]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_877638979319640068] = [HomeTeam] THEN &#13;&#10;    IF [FullTimeResult] = &apos;H&apos; THEN 3 &#13;&#10;    ELSEIF [FullTimeResult] = &apos;D&apos; THEN 1 &#13;&#10;    ELSE 0 &#13;&#10;    END&#13;&#10;ELSE&#13;&#10;    IF [FullTimeResult] = &apos;A&apos; THEN 3 &#13;&#10;    ELSEIF [FullTimeResult] = &apos;D&apos; THEN 1 &#13;&#10;    ELSE 0 &#13;&#10;    END&#13;&#10;END' />
      </column>
      <column caption='Home_win' datatype='boolean' name='[Calculation_877638979315777537]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[FullTimeResult] ==&apos;H&apos;' />
      </column>
